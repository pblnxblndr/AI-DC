<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>U.S. Data Center Construction Spending Growth</title>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 24px;
    }
    .chart-wrapper {
      background: #000;
      padding: 32px 28px 48px;
      border-radius: 8px;
      width: 100%;
      max-width: 820px;
      font-family: 'DotGothic16', monospace;
    }
    .chart-title {
      color: #aaa;
      font-family: 'DotGothic16', monospace;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 4px;
    }
    .chart-subtitle {
      color: #555;
      font-family: 'DotGothic16', monospace;
      font-size: 11px;
      letter-spacing: 1px;
      margin-bottom: 24px;
    }
    .chart-container {
      position: relative;
      width: 100%;
      height: 400px;
    }
    .chart-footnote {
      color: #444;
      font-family: 'DotGothic16', monospace;
      font-size: 10px;
      letter-spacing: 1px;
      margin-top: 16px;
    }
  </style>
</head>
<body>
  <div class="chart-wrapper">
    <p class="chart-title">U.S. Data Center Construction Spending</p>
    <p class="chart-subtitle">Annual starts in billions USD — Source: ConstructConnect / U.S. Census Bureau</p>
    <div class="chart-container">
      <canvas id="dcChart"
        role="img"
        aria-label="Bar chart showing U.S. data center construction spending growth from 2019 to 2025. Spending grew from 8.5 billion in 2019 to over 60 billion in 2025, with explosive growth beginning in 2023.">
        Construction spending: 2019: $8.5B, 2020: $9.8B, 2021: $12.3B, 2022: $18.5B, 2023: $16.5B, 2024: $28.5B, 2025: $62B (est.)
      </canvas>
    </div>
    <p class="chart-footnote">* 2025 figure is full-year estimate based on YTD data through Nov 2025 (ConstructConnect)</p>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <script>
    const years = ['2019','2020','2021','2022','2023','2024','2025*'];
    const values = [8.5, 9.8, 12.3, 18.5, 16.5, 28.5, 62];
    const colors = years.map((y) => y === '2025*' ? '#00ff41' : '#888888');

    new Chart(document.getElementById('dcChart'), {
      type: 'bar',
      data: {
        labels: years,
        datasets: [{
          data: values,
          backgroundColor: colors,
          borderColor: colors,
          borderWidth: 0,
          borderRadius: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#111',
            titleColor: '#00ff41',
            bodyColor: '#ccc',
            borderColor: '#333',
            borderWidth: 1,
            titleFont: { family: "'DotGothic16', monospace", size: 12 },
            bodyFont: { family: "'DotGothic16', monospace", size: 12 },
            callbacks: {
              label: ctx => ' $' + ctx.parsed.y + 'B'
            }
          }
        },
        scales: {
          x: {
            grid: { color: 'rgba(255,255,255,0.06)' },
            border: { color: 'rgba(255,255,255,0.15)' },
            ticks: {
              color: ctx => ctx.index === 6 ? '#00ff41' : '#999',
              font: { family: "'DotGothic16', monospace", size: 11 },
              maxRotation: 0,
              autoSkip: false
            }
          },
          y: {
            grid: { color: 'rgba(255,255,255,0.06)' },
            border: { color: 'rgba(255,255,255,0.15)', dash: [4, 4] },
            ticks: {
              color: '#666',
              font: { family: "'DotGothic16', monospace", size: 11 },
              callback: v => '$' + v + 'B'
            },
            beginAtZero: true,
            max: 70
          }
        }
      }
    });
  </script>
</body>
</html>
